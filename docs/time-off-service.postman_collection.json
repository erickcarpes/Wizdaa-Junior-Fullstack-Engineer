              "raw": "{\n  \"employeeId\": \"emp-happy-1\",\n  \"locationId\": \"loc-a\",\n  \"availableDays\": 10\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/mock-hcm/admin/balances",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "mock-hcm",
                "admin",
                "balances"
